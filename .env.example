# Copy this file to .env.local and fill in your real values.
# .env.local is gitignored — never commit real keys.

# --- App ---
# The public base URL of your app (no trailing slash). In local dev this is
# http://localhost:3000 ; in production it's your real domain.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase (Database + Auth) ---
# From your Supabase project: Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key is SECRET — server only. Used by the redirect + webhook to
# write rows without a logged-in user session.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Google Safe Browsing (link safety scan) ---
# Create a key at https://console.cloud.google.com -> enable "Safe Browsing API"
GOOGLE_SAFE_BROWSING_KEY=your-safe-browsing-key

# --- Razorpay (the Starter tier) ---
# Dashboard -> Settings -> API Keys. Use TEST-mode keys (rzp_test_...) while building.
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=your-key-secret
# Settings -> Webhooks: create one pointing at /api/razorpay/webhook, set its secret here.
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret
# The Plan ID of your Starter subscription (create a Plan in the Razorpay dashboard).
RAZORPAY_PLAN_ID=plan_xxx

# --- Free tier limit ---
# How many links a free user may create per calendar month.
FREE_LINKS_PER_MONTH=25
